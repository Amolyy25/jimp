// persn.me — Prisma schema.
// Each user owns exactly one Profile; the profile's slug is the vanity URL.
// `slugChangedAt` gates the 7-day slug cooldown in the API layer.
// Spotify tokens are stored per-user so their Spotify OAuth lives independently
// of the profile blob (and never lands in a shareable URL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String    @unique
  // Optional — users who registered exclusively via Discord OAuth do not
  // have a local password. They sign in via the Discord button instead.
  password            String?
  role                Role      @default(USER)
  
  // Moderation
  isBanned            Boolean   @default(false)
  banReason           String?
  
  createdAt           DateTime  @default(now())

  // Email validation flow
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique

  // Spotify — optional. When present, the /api/spotify/now-playing/:userId
  // endpoint can stream live playback into the viewer's profile.
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  spotifyExpiresAt    DateTime?

  // Discord — set when the user has linked or registered through Discord
  // OAuth. `discordAvatar` is the avatar hash; the CDN URL is built on read.
  discordId           String?   @unique
  discordUsername     String?
  discordAvatar       String?

  profile             Profile?

  follows             Follow[]          @relation("Follower")
  followers           Follow[]          @relation("Followee")
  guestbookEntries    GuestbookEntry[]
}

model Profile {
  id            String   @id @default(cuid())
  slug          String   @unique
  data          Json
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  slugChangedAt DateTime @default(now())
  
  // Moderation
  isBanned      Boolean  @default(false)
  isNsfw        Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Clicker-game counter — incremented atomically by /api/clicker/:slug
  // (every visitor's clicks land here). Indexed DESC for the leaderboard.
  clickerScore  Int      @default(0)

  versions      ProfileVersion[]
  views         ViewEvent[]
  clicks        ClickEvent[]
  followedBy    Follow[]
  guestbook     GuestbookEntry[]
  questions     Question[]
  askerBlocks   AskerBlock[]
  reports       Report[]

  @@index([slug])
  @@index([clickerScore])
}

model ProfileVersion {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}

model ViewEvent {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // Hashed session ID — anonymous, rotated salt, no IP.
  sessionId  String
  referer    String?
  country    String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([profileId, sessionId])
}

model ClickEvent {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // e.g. "socials" or "discordServers" — matches data-widget-type
  kind      String
  // The href that was clicked.
  target    String
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followeeId String
  followee   User     @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)
  // Cached pointer to the followee's profile so feeds avoid extra joins.
  profileId  String?
  profile    Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([followerId, followeeId])
  @@index([followerId])
  @@index([followeeId])
}

// Anonymous Q&A: visitors can drop a question on a profile without an
// account. Only the owner sees PENDING entries; ANSWERED entries surface
// publicly via the Q&A widget. `askerHash` is a daily-rotated salted hash
// used solely for rate limiting + soft-blocking — never exposed and never
// reversible to an IP after the salt rotates.
model Question {
  id         String        @id @default(cuid())
  profileId  String
  profile    Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  body       String
  answer     String?
  answeredAt DateTime?
  askerHash  String
  status     QStatus       @default(PENDING)
  createdAt  DateTime      @default(now())

  @@index([profileId, status, createdAt])
  @@index([profileId, askerHash])
  @@index([profileId, createdAt])
}

enum QStatus {
  PENDING
  ANSWERED
  HIDDEN
  BLOCKED
}

// Per-profile soft-block list: an owner can prevent a specific anonymous
// asker from sending again. We persist the daily-rotated hash, so a block
// effectively expires when the salt rotates (~24h). This is intentional —
// permanent IP bans against anonymous traffic are RGPD-fragile and easily
// circumvented anyway. Repeat offenders get re-blocked automatically.
model AskerBlock {
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  askerHash  String
  createdAt  DateTime @default(now())

  @@id([profileId, askerHash])
  @@index([profileId])
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, authorId])
  @@index([profileId, createdAt])
}

model Report {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reason        String
  details       String?
  reporterIp    String?
  status        ReportStatus @default(PENDING)
  createdAt     DateTime @default(now())

  @@index([profileId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

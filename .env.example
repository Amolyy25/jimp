# ------------------------------------------------------------
# persn.me — environment variables
# Copy this file to `.env` for local dev, or configure them in
# your Railway project's Variables tab.
# ------------------------------------------------------------

# --- Required in ALL environments ----------------------------

# PostgreSQL connection string. On Railway, attach a Postgres
# plugin and reference it with: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/persn"

# Secret used to sign auth cookies (JWT). Pick a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-in-production"


# --- Production-only ----------------------------------------

# Node env — Railway sets this automatically, but keep here as a reference.
NODE_ENV="production"

# Port — Railway injects $PORT; this is a fallback.
PORT="3001"

# Optional: if the frontend and API are on different origins (e.g.
# persn.me + api.persn.me), list allowed origins here, comma-separated.
# If empty, the server reflects whatever origin requests come from.
CORS_ORIGINS="https://persn.me,https://www.persn.me"


# --- Frontend (Vite) ----------------------------------------

# Override the API baseURL at build time. Leave unset when the API is
# served by the same origin as the SPA (recommended on Railway — one service).
# VITE_API_URL="https://api.persn.me/api"


# --- Spotify OAuth (optional — enables live Now Playing widget) ---

# Register a Spotify app at https://developer.spotify.com/dashboard
# Add both redirect URIs (dev + prod) in the Spotify dashboard.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:5173/api/spotify/callback"

# Where to send the user after OAuth completes. Include the scheme.
# Example prod: https://persn.me
PUBLIC_APP_URL="http://localhost:5173"


# --- Discord OAuth (sign-in / sign-up + avatar import) -------------

# Register an app at https://discord.com/developers/applications
# Add the redirect URI in the OAuth2 → Redirects section.
# Required scopes are `identify email` (set automatically by the server).
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="https://www.persn.me/api/auth/discord/callback"


# --- Discord Presence widget (backend → bot pull) ------------------

# Base URL of the gateway bot's HTTP API. Backend fetches
#   GET ${BOT_API_URL}/presence/:discordId
# with header `x-bot-secret: ${BOT_SECRET}`. The bot returns 200 +
# presence JSON if the user is in the guild, 404 otherwise.
# Examples:
#   Local:           http://localhost:8787
#   Railway private: http://${{bot.RAILWAY_PRIVATE_DOMAIN}}:8787
BOT_API_URL=""

# Shared secret between the bot and the backend. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_SECRET=""

# The Discord guild (server) ID the bot watches. Used by the bot only —
# the backend doesn't read this directly.
DISCORD_SERVER_ID=""

# Public invite URL shown by the Discord Presence widget when a viewer
# isn't in the server. Browser-side, hence the VITE_ prefix.
VITE_DISCORD_INVITE="https://discord.gg/your_invite"


# --- CAP captcha (optional — PoW bot challenge) ----------------------

# Self-hosted CAPTCHA from https://github.com/tiagozip/cap.
# When CAP_ENABLED=true, the server enforces verification on the Q&A
# widget submit + the auth (login/register) endpoints. Token storage is
# in-memory (single-instance). The frontend mirror VITE_CAP_ENABLED must
# match so the SPA actually solves a challenge before posting.
CAP_ENABLED=""
VITE_CAP_ENABLED=""


# --- Email (optional — enables email verification) ------------------

# Sign up at https://resend.com/ and get an API key.
# Once set, users will receive a verification email on registration.
RESEND_API_KEY=""

# The public origin of your app (used in emails).
# Example: https://persn.me
PUBLIC_ORIGIN="https://persn.me"


# --- Twitch (optional — enables the Twitch Stream widget) ----------

# Register an application at https://dev.twitch.tv/console/apps
# Server-to-server flow, no per-user OAuth needed.
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
